---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { CATEGORIES } from '~/config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allPosts = (await getCollection('posts', ({ data }) => !data.draft)).filter(
  (p) => p.data.category === category.slug
);
const sorted = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title={`${category.label}の記事一覧`} description={category.description}>
  <section class="category-hero">
    <div class="hero-inner">
      <p class="category-eyebrow">CATEGORY {category.number}</p>
      <h1 class="category-name">{category.label}</h1>
      <p class="category-description">{category.description}</p>
      <p class="category-stats">
        公開済み <strong>{sorted.length}</strong> 本 / 想定 {category.expectedCount} 本
      </p>
    </div>
  </section>

  <section class="post-list-section">
    <div class="list-inner">
      {sorted.length === 0 ? (
        <p class="empty">このカテゴリの記事は準備中です。柱記事から先にご覧ください。</p>
      ) : (
        <ul class="post-list">
          {sorted.map((post) => (
            <li>
              <a href={`/posts/${post.id}/`} class="post-card">
                <div class="post-card-meta">
                  <span class="post-date">
                    {post.data.publishedAt.toLocaleDateString('ja-JP', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </span>
                  {post.data.isPillar && <span class="pillar-badge">PILLAR</span>}
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-description">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <ul class="post-tags">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <li>#{tag}</li>
                    ))}
                  </ul>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .category-hero {
    background-color: var(--color-onyx);
    color: var(--color-offwhite);
    padding: 5rem 1.25rem 4rem;
  }

  .hero-inner {
    max-width: var(--container-grid);
    margin: 0 auto;
  }

  .category-eyebrow {
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    color: var(--color-gold);
    margin: 0 0 0.6em 0;
    font-weight: 600;
  }

  .category-name {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 1.5rem + 1.5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-offwhite);
    margin: 0 0 0.6em 0 !important;
    border: none !important;
    padding: 0 !important;
  }

  .category-name::before {
    display: none !important;
  }

  .category-description {
    font-size: 1rem;
    line-height: 1.85;
    max-width: 36em;
    color: rgba(250, 250, 247, 0.85);
    margin: 0 0 1.6em 0;
  }

  .category-stats {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: rgba(250, 250, 247, 0.6);
    margin: 0;
  }

  .category-stats strong {
    color: var(--color-gold);
    font-weight: 700;
  }

  .post-list-section {
    background-color: var(--color-offwhite);
  }

  .list-inner {
    max-width: var(--container-grid);
    margin: 0 auto;
    padding: 4rem 1.25rem 5rem;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3em 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .post-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .post-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 1.6rem;
    background-color: var(--color-offwhite);
    border: 1px solid var(--color-mist);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
  }

  .post-card:hover {
    border-color: var(--color-gold);
    text-decoration: none;
    box-shadow: var(--shadow-card);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.8em;
    margin-bottom: 0.8em;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .pillar-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    color: var(--color-gold);
    background-color: var(--color-onyx);
    padding: 0.2em 0.55em;
    font-weight: 700;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.5;
    margin: 0 0 0.7em 0 !important;
    border: none !important;
    padding: 0 !important;
    color: var(--color-onyx);
  }

  .post-title::before {
    display: none !important;
  }

  .post-description {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 1em 0;
    flex: 1;
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
    font-size: 0.7rem;
    color: var(--color-slate);
    font-family: var(--font-mono);
  }
</style>
