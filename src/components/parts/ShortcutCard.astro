---
/**
 * ShortcutCard — キーボードショートカットをキーキャップ風に表示
 */
export interface Props {
  keys: string[];
  description: string;
  category?: string;
}

const { keys, description, category } = Astro.props;
---

<div class="shortcut-card">
  <div class="shortcut-keys">
    {keys.map((key, i) => (
      <>
        <kbd class="key">{key}</kbd>
        {i < keys.length - 1 && <span class="plus">+</span>}
      </>
    ))}
  </div>
  <div class="shortcut-meta">
    {category && <p class="category">{category}</p>}
    <p class="description">{description}</p>
  </div>
</div>

<style>
  .shortcut-card {
    display: grid;
    grid-template-columns: minmax(7rem, auto) 1fr;
    gap: 1.2rem;
    align-items: center;
    padding: 0.9rem 1.1rem;
    background-color: var(--color-offwhite);
    border: 1px solid var(--color-mist);
    border-radius: 4px;
    margin-block: 0.6em;
  }

  .shortcut-keys {
    display: flex;
    align-items: center;
    gap: 0.3em;
    flex-wrap: wrap;
  }

  .key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-offwhite);
    background-color: var(--color-onyx);
    border: 1px solid var(--color-onyx);
    border-bottom: 2px solid #000;
    padding: 0.25em 0.6em;
    border-radius: 4px;
    min-width: 1.6em;
    line-height: 1.3;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.4);
  }

  .plus {
    color: var(--color-slate);
    font-weight: 600;
    font-size: 0.85em;
  }

  .shortcut-meta {
    line-height: 1.5;
  }

  .category {
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    color: var(--color-gold);
    font-weight: 600;
    margin: 0 0 0.15em 0;
    text-transform: uppercase;
  }

  .description {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
  }
</style>
