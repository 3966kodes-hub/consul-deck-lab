---
/**
 * ConsultantQuote — コンサル原則・著名人の名言を引用
 */
export interface Props {
  source?: string;
  book?: string;
}

const { source, book } = Astro.props;
---

<figure class="consultant-quote">
  <span class="quote-mark" aria-hidden="true">&ldquo;</span>
  <blockquote>
    <slot />
  </blockquote>
  {(source || book) && (
    <figcaption>
      {source && <cite class="source">{source}</cite>}
      {book && <span class="book">『{book}』</span>}
    </figcaption>
  )}
</figure>

<style>
  .consultant-quote {
    margin: 2.4em 0;
    padding: 0 0 0 3.5em;
    position: relative;
    font-family: var(--font-serif);
  }

  .quote-mark {
    position: absolute;
    top: -0.3em;
    left: 0;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    color: var(--color-gold);
    font-weight: 700;
    user-select: none;
  }

  blockquote {
    margin: 0;
    padding: 0;
    background-color: transparent;
    border: none;
    font-style: normal;
    font-size: 1.1em;
    line-height: 1.75;
    color: var(--color-onyx);
    font-weight: 500;
  }

  blockquote :global(p) {
    margin: 0;
  }

  figcaption {
    margin-top: 0.8em;
    font-family: var(--font-sans);
    font-size: 0.85em;
    color: var(--color-text-muted);
    font-style: normal;
  }

  .source {
    font-style: normal;
    font-weight: 500;
    color: var(--color-navy);
  }

  .book {
    margin-left: 0.4em;
  }
</style>
