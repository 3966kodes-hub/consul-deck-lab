---
import { SITE, NAV_ITEMS } from '~/config';
import { Icon } from 'astro-icon/components';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label={`${SITE.name} トップへ`}>
      <span class="logo-mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="28" height="28">
          <rect x="4" y="8" width="18" height="14" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(-6 13 15)" />
          <rect x="10" y="10" width="18" height="14" fill="#C9A55C" transform="rotate(6 19 17)" />
        </svg>
      </span>
      <span class="logo-text">
        <span class="logo-en">CONSUL DECK LAB</span>
        <span class="logo-ja">コンサルデッキ ラボ</span>
      </span>
    </a>

    <nav class="primary-nav" aria-label="主要ナビゲーション">
      <ul>
        {NAV_ITEMS.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <a href="/search/" class="search-link" aria-label="サイト内検索">
      <Icon name="lucide:search" width={20} height={20} />
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--color-onyx);
    color: var(--color-offwhite);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .header-inner {
    max-width: var(--container-grid);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: inherit;
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-gold-light);
  }

  .logo-mark {
    color: var(--color-offwhite);
    display: inline-flex;
    align-items: center;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-en {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    color: var(--color-gold);
  }

  .logo-ja {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--color-offwhite);
    margin-top: 0.1em;
  }

  .primary-nav {
    flex: 1;
    display: none;
  }

  .primary-nav ul {
    display: flex;
    gap: 1.6rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .primary-nav a {
    color: var(--color-offwhite);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.15s ease;
    position: relative;
    padding: 0.4em 0;
  }

  .primary-nav a:hover {
    color: var(--color-gold);
  }

  .primary-nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-gold);
    transition: width 0.2s ease;
  }

  .primary-nav a:hover::after {
    width: 100%;
  }

  .search-link {
    color: var(--color-offwhite);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .search-link:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  @media (min-width: 1024px) {
    .primary-nav {
      display: block;
    }
  }
</style>
