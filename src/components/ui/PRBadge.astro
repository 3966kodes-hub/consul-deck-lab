---
/**
 * PRBadge — アフィリエイトリンク明示・景表法対応
 * 全記事のアフィリンク前後に必須配置
 */
export interface Props {
  text?: string;
}

const { text = 'PR' } = Astro.props;
---

<span class="pr-badge" aria-label="プロモーション表記">{text}</span>

<style>
  .pr-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-amber);
    background-color: transparent;
    border: 1px solid var(--color-amber);
    padding: 0.15em 0.45em;
    border-radius: 2px;
    text-transform: uppercase;
    line-height: 1.3;
    vertical-align: middle;
    margin-inline: 0.2em;
    user-select: none;
  }
</style>
