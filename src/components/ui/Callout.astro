---
/**
 * Callout — 注意・補足・警告・情報
 */
export type CalloutType = 'info' | 'warning' | 'success' | 'danger' | 'note';

export interface Props {
  type?: CalloutType;
  title?: string;
}

const { type = 'info', title } = Astro.props;

const ICON: Record<CalloutType, string> = {
  info: 'ℹ',
  note: '✎',
  warning: '⚠',
  success: '✓',
  danger: '✗',
};
---

<aside class={`callout callout-${type}`} role="note">
  <div class="callout-icon" aria-hidden="true">{ICON[type]}</div>
  <div class="callout-content">
    {title && <p class="callout-title">{title}</p>}
    <div class="callout-body"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 0.9em;
    margin-block: 1.6em;
    padding: 1em 1.2em;
    background-color: var(--color-bone);
    border-left: 3px solid var(--color-slate);
    border-radius: 2px;
  }

  .callout-info {
    border-left-color: var(--color-navy);
  }

  .callout-note {
    border-left-color: var(--color-slate);
  }

  .callout-warning {
    border-left-color: var(--color-amber);
    background-color: rgba(184, 134, 11, 0.05);
  }

  .callout-success {
    border-left-color: var(--color-sage);
    background-color: rgba(92, 140, 126, 0.06);
  }

  .callout-danger {
    border-left-color: var(--color-brick);
    background-color: rgba(139, 58, 58, 0.05);
  }

  .callout-icon {
    flex-shrink: 0;
    width: 1.4em;
    height: 1.4em;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    line-height: 1;
    font-size: 0.95em;
  }

  .callout-info .callout-icon { color: var(--color-navy); }
  .callout-note .callout-icon { color: var(--color-slate); }
  .callout-warning .callout-icon { color: var(--color-amber); }
  .callout-success .callout-icon { color: var(--color-sage); }
  .callout-danger .callout-icon { color: var(--color-brick); }

  .callout-content {
    flex: 1;
  }

  .callout-title {
    font-weight: 700;
    margin: 0 0 0.3em 0;
    font-family: var(--font-serif);
    color: var(--color-onyx);
  }

  .callout-body :global(p) {
    margin-block: 0.4em;
    font-size: 0.95em;
  }

  .callout-body :global(p:first-child) {
    margin-top: 0;
  }

  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
